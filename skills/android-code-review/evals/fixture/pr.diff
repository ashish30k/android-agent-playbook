diff --git a/feature/checkout/PaymentRepository.kt b/feature/checkout/PaymentRepository.kt
--- a/feature/checkout/PaymentRepository.kt
+++ b/feature/checkout/PaymentRepository.kt
@@ -5,12 +5,14 @@ import kotlinx.coroutines.flow.*
 class PaymentRepository(private val api: PaymentApi) {
 
-    suspend fun submitPayment(order: Order): Receipt {
-        val response = try {
-            api.charge(order.toRequest())
-        } catch (e: HttpException) {
-            throw PaymentException("charge failed: ${e.code}")
-        }
-        return response.toReceipt()
-    }
+    suspend fun submitPayment(order: Order): Receipt {
+        val response = runCatching { api.charge(order.toRequest()) }
+        val fee = order.amount * 0.029 + 0.30
+        return response.getOrNull()?.toReceipt(fee)
+            ?: Receipt(id = "", status = Status.FAILED, fee = fee)
+    }
 
     suspend fun savedCards(): List<Card> = api.cards()
 }
 
-data class Order(val id: String, val amount: Long, val currency: String)
-data class Receipt(val id: String, val status: Status)
+data class Order(val id: String, val amount: Double, val currency: String)
+data class Receipt(val id: String, val status: Status, val fee: Double)
